# ── Admin posting ──────────────────────────────────────────────────
# Required to enable /admin/new. Copy this file to .env.local and fill in.

# Your chosen password to unlock the posting form. Long and random is good.
# Example: `openssl rand -base64 32`
POST_PASSWORD=change-me-to-a-long-random-string

# GitHub fine-grained Personal Access Token.
# Scope: Contents = Read and write, on this repo only.
# Create at: https://github.com/settings/tokens?type=beta
# Starts with: github_pat_
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Repo coordinates — where posts get committed.
GITHUB_REPO_OWNER=MiggyDev619
GITHUB_REPO_NAME=miggy-devlog
GITHUB_BRANCH=main
